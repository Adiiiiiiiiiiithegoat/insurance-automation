# ============================================================
#  Insurance Automation - credentials
#  Copy this file to `.env` and fill in your real logins, then SAVE.
#  `.env` is git-ignored and must NEVER be committed or shared.
# ============================================================
# --- Muscat Insurance (MIC) - REQUIRED (the web control panel uses this) ---
MIC_USERNAME=your_mic_username_here
MIC_PASSWORD=your_mic_password_here
# --- New India Assurance - REQUIRED to process New India records in the control panel ---
NI_USERNAME=
NI_PASSWORD=
# --- IRAN Insurance - optional (only needed for the IRAN flow) ---
IRAN_USERNAME=
IRAN_PASSWORD=
